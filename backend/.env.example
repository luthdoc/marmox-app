# =============================================================================
# Marmax Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# --- Supabase ---
# URL do projeto Supabase (ex: https://xyzxyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Chave de serviço do Supabase (service role key — acesso irrestrito ao banco)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Anthropic ---
# Chave da API Anthropic para acesso ao Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Z-API (WhatsApp) ---
# ID da instância Z-API do tenant
ZAPI_INSTANCE_ID=your-zapi-instance-id

# Token de autenticação da instância Z-API
ZAPI_TOKEN=your-zapi-token

# --- Aplicação (opcionais) ---
# Ambiente de execução: development | production (padrão: development)
APP_ENV=development

# Nível de log: DEBUG | INFO | WARNING | ERROR | CRITICAL (padrão: INFO)
LOG_LEVEL=INFO
