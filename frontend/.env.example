# =============================================================================
# Marmax Frontend — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env.local no repositório.
# =============================================================================

# --- Supabase (públicas — expostas no browser) ---
# URL do projeto Supabase (ex: https://xyzxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anon do Supabase (segura para uso no cliente — RLS protege os dados)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Aplicação (pública) ---
# Ambiente de execução: development | production (padrão: development)
NEXT_PUBLIC_APP_ENV=development
